from enum import Enum


class TaskStatus(Enum):
    """Lifecycle states for a care task."""
    NOT_STARTED = "Not Started"
    IN_PROGRESS = "In Progress"
    COMPLETED = "Completed"
    CANCELLED = "Cancelled"


class Priority(Enum):
    """Priority levels used by the Scheduler to order tasks."""
    HIGH = 3
    MEDIUM = 2
    LOW = 1


